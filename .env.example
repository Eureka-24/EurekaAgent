# AgentFrame 环境配置示例
# 复制此文件为 .env 并填写实际值

# ===========================================
# LLM Provider Configuration
# ===========================================

# DeepSeek Configuration (推荐，性价比高)
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# OpenAI Configuration (可选)
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# Anthropic Configuration (可选)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key
ANTHROPIC_MODEL=claude-3-5-sonnet-20240620

# Google Configuration (可选)
GOOGLE_API_KEY=your-google-api-key
GOOGLE_MODEL=gemini-1.5-pro

# ===========================================
# Storage Configuration
# ===========================================

# Vector Database (ChromaDB - 内置默认)
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_COLLECTION=agentframe

# Redis Configuration (可选)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# PostgreSQL Configuration (可选)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=agentframe
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-password

# ===========================================
# Application Settings
# ===========================================

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false
API_WORKERS=4

# Security
SECRET_KEY=your-secret-key-change-in-production
API_KEY_HEADER=X-API-Key

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# ===========================================
# Development Settings
# ===========================================

# Enable debug mode (development only)
DEBUG=false

# Enable auto-reload (development only)
RELOAD=false
